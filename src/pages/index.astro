---
import Layout from '~/layouts/PageLayout.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

// Importamos la imagen igual que hiciste en el otro archivo
import img1 from '~/assets/images/img1.png';

const metadata = {
  title: 'Widows Sons MRA - Capítulo Rio Uruguay',
};
---

<Layout metadata={metadata}>

  <section class="relative h-screen flex items-center justify-center bg-black overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img 
        src={img1.src} 
        alt="Fondo Widows Sons" 
        class="w-full h-full object-cover opacity-60"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-transparent to-black"></div>
    </div>

    <div class="relative z-10 text-center px-4 max-w-5xl mx-auto">
      <h1 class="text-5xl md:text-7xl font-extrabold text-white mb-6 uppercase" style="text-shadow: 2px 2px 10px rgba(0,0,0,0.8);">
        WIDOWS SONS <br />
        <span class="text-[#d4af37]">CAPÍTULO RIO URUGUAY</span>
      </h1>
      
      <p class="text-xl md:text-2xl text-zinc-200 mb-10 max-w-3xl mx-auto" style="text-shadow: 1px 1px 5px rgba(0,0,0,0.8);">
        Asociación Internacional de Maestros Masones Motociclistas.<br class="hidden sm:inline" />
        Libertad, Fraternidad y Ayuda Mutua en las rutas del litoral.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#contacto" class="bg-[#d4af37] hover:bg-white text-black font-bold py-4 px-10 rounded-full transition duration-300 no-underline uppercase tracking-widest">
          Unirse a la Ruta
        </a>
      </div>
    </div>
  </section>

  ...
</Layout>
