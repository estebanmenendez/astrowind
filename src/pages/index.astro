---
import Layout from '~/layouts/PageLayout.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Widows Sons MRA - Capítulo Rio Uruguay',
};
---

<Layout metadata={metadata}>

  <section class="relative h-screen flex items-center justify-center bg-black overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img 
        src="/src/assets/images/img1.png" 
        alt="Fondo" 
        class="w-full h-full object-cover opacity-50"
      />
      <div class="absolute inset-0 bg-black/40"></div>
    </div>

    <div class="relative z-10 text-center px-4 max-w-5xl mx-auto">
      <h1 class="text-5xl md:text-7xl font-extrabold text-white mb-6 uppercase">
        WIDOWS SONS <br />
        <span class="text-[#d4af37]">CAPÍTULO RIO URUGUAY</span>
      </h1>
      
      <p class="text-xl text-zinc-200 mb-10 max-w-2xl mx-auto">
        Asociación Internacional de Maestros Masones Motociclistas.
      </p>

      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="#contacto" class="bg-[#d4af37] text-black font-bold py-3 px-8 rounded-full no-underline hover:bg-white transition">
          Unirse a la Ruta
        </a>
        <a href="#quienes-somos" class="text-white font-semibold py-3 px-8 no-underline hover:text-[#d4af37] transition">
          Saber más ↓
        </a>
      </div>
    </div>
  </section>

  <Content
    id="quienes-somos"
    isReversed
    tagline="Nuestra Esencia"
    title="Masonería y Motociclismo"
    items={[
      { title: 'Fraternidad', description: 'Compartimos la pasión por las rutas.' },
      { title: 'Historia', description: 'Nacidos en el litoral uruguayo.' }
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1558981806-ec527fa84c39?auto=format&fit=crop&w=2070&q=80',
      alt: 'Esencia',
    }}
  />

  <Features
    id="pilares"
    title="Nuestros Pilares"
    items={[
      { title: 'Libertad', description: 'El viento y el camino.', icon: 'tabler:wind' },
      { title: 'Fraternidad', description: 'Auxilio mutuo.', icon: 'tabler:users' },
      { title: 'Caridad', description: 'Compromiso social.', icon: 'tabler:heart' }
    ]}
  />

  <CallToAction
    id="contacto"
    title="Contacto"
    subtitle="Escríbenos si quieres rodar con nosotros."
    actions={[{ variant: 'primary', text: 'Enviar Mensaje', href: 'mailto:contacto@ejemplo.com' }]}
  />

</Layout>
