
---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Widows Sons MRA - Capítulo Rio Uruguay',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>


<Hero
    actions={[
      { variant: 'primary', text: 'Unirse a la Ruta', href: '#contacto', icon: 'tabler:steering-wheel' },
      { text: 'Saber más', href: '#quienes-somos' },
    ]}
    image={{ src: '~/assets/images/img1.png', alt: 'Widows Sons Rio Uruguay' }}
  >
    <Fragment slot="title">
      WIDOWS SONS <br />
      <span class="text-[#d4af37] highlight">CAPÍTULO RIO URUGUAY</span>
    </Fragment>

    <Fragment slot="subtitle">
      Asociación Internacional de Maestros Masones Motociclistas. <br class="hidden sm:inline" />
      Libertad, Fraternidad y Ayuda Mutua en las rutas del litoral uruguayo.
    </Fragment>
  </Hero>

  <Content
    id="quienes-somos"
    isReversed
    tagline="Nuestra Esencia"
    title="Masonería y Motociclismo"
    items={[
      {
        title: 'Fraternidad en Ruta',
        description:
          'No somos un Moto Club, somos una asociación de Hermanos que comparten la pasión por las dos ruedas bajo los principios de la Orden.',
      },
      {
        title: 'Historia del Capítulo',
        description:
          'El Capítulo Rio Uruguay nace con el fin de nuclear a los Maestros Masones del litoral, fortaleciendo los lazos fuera de los templos.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1558981806-ec527fa84c39?auto=format&fit=crop&w=2070&q=80',
      alt: 'Imagen representativa',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Más que una pasión, un estilo de vida</h3>
      Llevamos nuestros parches con honor, respetando las leyes y fomentando la caridad.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-zinc-900 dark:bg-transparent"></div>
    </Fragment>
  </Content>

 <Features
    id="pilares"
    tagline="Valores"
    title="Nuestros Pilares"
    subtitle="Los principios que guían nuestro camino en cada kilómetro recorrido."
    items={[
      {
        title: 'Libertad',
        description:
          'El viento en la cara y el camino por delante como expresión máxima de nuestro libre albedrío.',
        icon: 'tabler:wind', // <--- Cambiado de Wind a wind
      },
      {
        title: 'Fraternidad',
        description:
          'El auxilio mutuo y la mano extendida al hermano en cualquier circunstancia de la vida o la ruta.',
        icon: 'tabler:users', // <--- Asegúrate que esté en minúsculas
      },
      {
        title: 'Caridad',
        description:
          'El compromiso ineludible con la viuda y el huérfano, llevando ayuda donde sea necesaria.',
        icon: 'tabler:heart', // <--- Asegúrate que esté en minúsculas
      },
    ]}
  />

  <Steps
    title="¿Quieres ser parte del Capítulo?"
    items={[
      {
        title: 'Paso 1: <span class="font-medium">Ser Maestro Masón</span>',
        description:
          "Es requisito indispensable pertenecer a una Logia regular y tener el grado de Maestro Masón en plenitud de sus derechos.",
        icon: 'tabler:certificate',
      },
      {
        title: 'Paso 2: <span class="font-medium">Poseer Motocicleta</span>',
        description:
          "Compartir la pasión por el motociclismo y poseer una moto de cilindrada adecuada para rutas nacionales.",
        icon: 'tabler:motorbike',
      },
      {
        title: 'Paso 3: <span class="font-medium">Contacto</span>',
        description:
          'Escríbenos para conocernos en una de nuestras salidas abiertas o eventos sociales.',
        icon: 'tabler:message',
      },
      {
        title: '¡Listos para rodar!',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1616198814651-e71f960c3180?auto=format&fit=crop&w=987&q=80',
      alt: 'Imagen pasos',
    }}
  />

  <CallToAction
    id="contacto"
    actions={[
      {
        variant: 'primary',
        text: 'Enviar Mensaje',
        href: 'mailto:contacto@tu-dominio.com',
        icon: 'tabler:mail',
      },
    ]}
  >
    <Fragment slot="title">
      ¿Tienes alguna duda?
    </Fragment>

    <Fragment slot="subtitle">
      Si eres un Hermano del litoral y quieres rodar con nosotros, no dudes en contactar al Capítulo Rio Uruguay.
    </Fragment>
  </CallToAction>
</Layout>
