---
import Layout from '~/layouts/PageLayout.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro'; // Nueva importación

// Importación de imágenes
import img1 from '~/assets/images/img1.png';
import img2 from '~/assets/images/img2.png';

const metadata = {
  title: 'Widows Sons MRA - Capítulo Rio Uruguay',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <section class="relative h-screen flex items-center justify-center bg-black overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src={img1.src} alt="Fondo" class="w-full h-full object-cover opacity-60" />
      <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-transparent to-black"></div>
    </div>
    <div class="relative z-10 text-center px-4 max-w-5xl mx-auto">
      <h1 class="text-5xl md:text-7xl font-extrabold text-white mb-6 uppercase" style="text-shadow: 3px 3px 6px rgba(0,0,0,0.9);">
        WIDOWS SONS <br /> <span class="text-[#d4af37]">CAPÍTULO RIO URUGUAY</span>
      </h1>
      <p class="text-xl md:text-2xl text-zinc-200 mb-10 font-medium">
        Asociación Internacional de Maestros Masones Motociclistas.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#contacto" class="bg-[#d4af37] text-black font-bold py-4 px-10 rounded-full no-underline uppercase tracking-widest">Unirse a la Ruta</a>
        <a href="#eventos" class="text-white font-semibold py-4 px-10 no-underline">Próximos Eventos ↓</a>
      </div>
    </div>
  </section>

  <Content
    id="quienes-somos"
    isReversed
    tagline="Nuestra Historia"
    title="El rugido nació del martillo y el cincel"
    items={[
      {
        title: 'I. Hermandad',
        description: 'Somos hermanos antes que nada. El lazo fraterno precede a todo título y distinción.',
        icon: 'tabler:users-group',
      },
      {
        title: 'II. Rectitud',
        description: 'Actuamos con la escuadra como guía. Nuestra conducta debe ser recta en la Logia y en la ruta.',
        icon: 'tabler:square-rotated',
      },
      {
        title: 'III. Servicio',
        description: 'La causa de la viuda y el huérfano es nuestra razón. Cabalgamos para sostener al prójimo.',
        icon: 'tabler:heart-handshake',
      },
      {
        title: 'IV. Tradición',
        description: 'Honramos la Masonería Universal y respetamos sus antiguas usanzas en cada acción.',
        icon: 'tabler:old',
      },
    ]}
    image={{
      src: img2,
      alt: 'Hermanos del Chapter Rio Uruguay',
    }}
  >
    <Fragment slot="content">
      <div class="text-muted dark:text-slate-400">
        <p class="mb-4">
          Los <strong>Widows Sons</strong> son una asociación internacional de Hermanos Masones Maestros activos que se reúnen bajo la bandera del motociclismo desde finales de los años 90. Nuestro nombre —Hijos de la Viuda— es una referencia bíblica y masónica que alude a Hiram Abiff, el Maestro Constructor del Templo de Salomón.
        </p>
        <p class="mb-4">
          El <strong>Chapter Rio Uruguay</strong> fue fundado por un grupo de hermanos de ambas orillas del río, unidos por la pasión común del asfalto y la convicción masónica. Nuestro territorio simbólico son las rutas que bordean el Río Uruguay, un corredor de fraternidad entre naciones hermanas.
        </p>
        <p>
          Desde nuestra fundación, cada milla recorrida ha sido también un gesto de amor al prójimo: recaudaciones para escuelas rurales, hospitales y familias en necesidad jalonan nuestro camino.
        </p>
      </div>
      
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mt-8 mb-2">
        Nuestro Credo
      </h3>
      <p class="text-lg text-[#d4af37] font-semibold italic">
        Cuatro piedras angulares que ningún viento de ruta puede derribar.
      </p>
    </Fragment>
  </Content>

  <Features
    id="pilares"
    tagline="Valores"
    title="Pilares del Capítulo"
    items={[
      { title: 'Fraternidad', description: 'Lazos indisolubles entre Hermanos.', icon: 'tabler:users' },
      { title: 'Libertad', description: 'El motociclismo como expresión de libertad personal.', icon: 'tabler:wind' },
      { title: 'Caridad', description: 'Asistencia a la viuda y el huérfano.', icon: 'tabler:heart' },
      { title: 'Internacional', description: 'Parte de una hermandad global.', icon: 'tabler:world' },
      { title: 'Maestría', description: 'Integrado por Maestros Masones.', icon: 'tabler:certificate' },
      { title: 'Pasión', description: 'Motociclismo seguro y compañerismo.', icon: 'tabler:motorbike' },
    ]}
  />

  <BlogLatestPosts
    id="eventos"
    title="Próximos Eventos y Rodadas"
    information={`Participa en nuestras actividades, encuentros benéficos y salidas oficiales del Capítulo Rio Uruguay.`}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </BlogLatestPosts>

  <CallToAction
    id="contacto"
    actions={[{ variant: 'primary', text: 'Enviar Mensaje', href: 'mailto:contacto@ejemplo.com', icon: 'tabler:mail' }]}
  >
    <Fragment slot="title">¿Tienes alguna duda?</Fragment>
    <Fragment slot="subtitle">Si eres un Hermano del litoral y quieres rodar con nosotros, contáctanos.</Fragment>
  </CallToAction>

</Layout>
