---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Quiénes Somos — Widows Sons Río Uruguay',
};
---


<Layout metadata={metadata}>
  <Hero
    tagline="Nuestra Identidad"
    image={{
      src: '~/assets/images/default.png',
      alt: 'Widows Sons Río Uruguay',
    }}
  >
    <Fragment slot="title">
      Widows Sons <br />
      <span class="text-accent dark:text-white">Capítulo Río Uruguay</span>
    </Fragment>

    <Fragment slot="subtitle">
      Somos una hermandad de Maestros Masones activos que, bajo los principios universales de la Masonería, 
      encuentran en el motociclismo un vehículo de unión, servicio y presencia en la comunidad. 
      Nuestro nombre, <strong>“Hijos de la Viuda”</strong>, representa nuestro compromiso con la lealtad, 
      la integridad, la solidaridad y el honor.
    </Fragment>
  </Hero>

  <Stats
    title="Nuestra Misión"
    subtitle="La fraternidad no se declama, se demuestra."
    stats={[
      { title: 'Propósito', amount: 'Filantropía' },
      { title: 'Base', amount: 'Educación' },
      { title: 'Impacto', amount: 'Social' },
      { title: 'Motor', amount: 'Fraternidad' },
    ]}
  />

  <Features3
    title="Presencia en la Región"
    subtitle="Consolidando un espacio que trasciende fronteras geográficas y fortalece los vínculos humanos en el litoral oeste."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Paysandú',
        description:
          'Base de nuestras operaciones y gestión del Capítulo, coordinando acciones locales.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Salto',
        description:
          'Extensión de nuestra presencia fraternal y compromiso con la comunidad salteña.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Río Negro',
        description:
          'Punto clave de unión regional para nuestras rutas y paradas solidarias.',
        icon: 'tabler:map-pin',
      },
    ]}
  />

  <Steps2
    title="Nuestros Valores"
    subtitle="Los pilares masónicos que guían cada kilómetro de nuestra marcha."
    items={[
      {
        title: 'Fraternidad y Servicio',
        description:
          'Unión genuina entre hermanos y vocación constante de ayuda desinteresada a quienes más lo necesitan.',
      },
      {
        title: 'Respeto y Compromiso',
        description:
          'Respeto por las personas e instituciones, junto a una acción social sostenida y responsable en el tiempo.',
      },
      {
        title: 'Honor',
        description:
          'Mantenemos una coherencia absoluta entre lo que somos, lo que decimos y lo que hacemos en cada lugar donde estamos presentes.',
      },
    ]}
  />

  <Steps2
    title="Nuestro Compromiso"
    subtitle="No somos solo un grupo de motociclistas. Somos una hermandad que actúa, que construye y que deja huella."
    isReversed={true}
    callToAction={{
      text: 'Ver nuestras actividades',
      href: '/blog',
    }}
    items={[
      {
        title: 'Acción Concreta',
        description: 'Transformamos los principios en hechos visibles y sostenidos.',
        icon: 'tabler:tool',
      },
      {
        title: 'Vínculo Humano',
        description: 'Generamos impacto real uniendo las dos orillas del Río Uruguay.',
        icon: 'tabler:users-group',
      },
      {
        title: 'Referente Regional',
        description: 'Trabajamos para ser un ejemplo de civismo y fraternidad en la vía pública.',
        icon: 'tabler:certificate',
      },
    ]}
  />

  <Features2
    title="Dónde nos encontramos"
    tagline="Territorio"
    columns={3}
    items={[
      {
        title: 'Litoral Oeste',
        description: 'Zona principal de influencia y rodadas.',
      },
      {
        title: 'Sedes Masónicas',
        description: 'Puntos de encuentro institucional de nuestros miembros.',
      },
      {
        title: 'Rutas Solidarias',
        description: 'Presencia itinerante en comunidades locales.',
      },
    ]}
  />

  <Features2
    title="Contacto Institucional"
    tagline="Comunícate"
    columns={2}
    items={[
      {
        title: 'Mensaje Directo',
        description: 'Para coordinar apoyo en campañas o identificar familias que requieran asistencia.',
        icon: 'tabler:messages',
      },
      {
        title: 'Membresía',
        description: 'Información exclusiva para Maestros Masones interesados en el Capítulo.',
        icon: 'tabler:id-badge-2',
      },
    ]}
  />
</Layout>
